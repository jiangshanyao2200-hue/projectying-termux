    json!([
        {
            "type": "function",
            "name": "exec_command",
            "description": "Run a shell command. The normal path is a one-shot command for reading files, building, testing, or short scripts. Prefer a deterministic workflow: inspect narrowly first, then widen only if needed, then modify or verify. Set `tty=true` only when the program must stay alive, needs interactive input, or should keep running in the background; those PTY sessions later continue through `write_stdin` and eventually emit a terminal summary. Avoid PTY for simple reads or quick commands. At most 5 PTY sessions can run at once. When several independent read/search/status calls are needed, emit them directly in the same round; the runtime can batch eligible read-only calls natively.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "cmd": {
                        "type": "string",
                        "description": "Shell command to execute. Prefer precise, low-risk commands over giant dumps; read the smallest useful slice first."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese purpose sentence for UI display, such as µ¤źń£ŗÕĮōÕēŹńø«ÕĮĢ or Ķ┐ÉĶĪī Rust µĄŗĶ»Ģ."
                    },
                    "workdir": {
                        "type": "string",
                        "description": "Optional working directory to run the command in; defaults to the current ProjectYing project root. Relative paths resolve from the project root; use absolute paths for external directories. `home` / `home/...` is treated as a Termux home alias."
                    },
                    "shell": {
                        "type": "string",
                        "description": "Shell binary to launch. Defaults to the user's default shell."
                    },
                    "tty": {
                        "type": "boolean",
                        "description": "Whether to allocate a TTY for the command. Default is false for one-shot execution. Set true only for interactive shells, long-running programs, or background terminal work that you will continue with `write_stdin`."
                    },
                    "yield_time_ms": {
                        "type": "number",
                        "description": "How long to wait for output before yielding. Use a short wait for quick reads and a longer wait for builds, tests, or commands that need startup time."
                    },
                    "output_level": {
                        "type": "string",
                        "enum": ["low", "medium", "high"],
                        "description": "Visible output budget for one-shot commands. Default is `medium`. Presets are low=120 lines / 36000 chars, medium=320 lines / 96000 chars, high=520 lines / 156000 chars, with live values controlled by Settings -> õĖŖõĖŗµ¢ć. If visible output exceeds the chosen line or character budget, the full output is exported to an external file and only a summary is returned. Use a higher level only when the extra context is genuinely useful; a hidden 5 MB safety cap still applies."
                    },
                    "max_output_tokens": {
                        "type": "number",
                        "description": "Legacy optional token cap applied after line-budget/export handling."
                    },
                    "timeout_secs": {
                        "type": "number",
                        "description": "Optional terminal timeout in seconds for `tty=true` sessions. Use this to bound long-running jobs. Background terminals default to a timeout; fully interactive PTY sessions default to no timeout unless you set one."
                    },
                    "report_interval_secs": {
                        "type": "number",
                        "description": "Optional periodic snapshot interval in seconds for `tty=true` sessions. Use this only for long-running work where periodic progress matters; snapshots are deduplicated per session."
                    },
                    "login": {
                        "type": "boolean",
                        "description": "Whether to run the shell with -l/-i semantics. Defaults to true."
                    }
                },
                "required": ["cmd"],
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "chunk_id": {
                        "type": "string",
                        "description": "Chunk identifier included when the response reports one."
                    },
                    "wall_time_seconds": {
                        "type": "number",
                        "description": "Elapsed wall time spent waiting for output in seconds."
                    },
                    "exit_code": {
                        "type": "number",
                        "description": "Process exit code when the command finished during this call."
                    },
                    "session_id": {
                        "type": "number",
                        "description": "Session identifier to pass to write_stdin when the process is still running."
                    },
                    "original_token_count": {
                        "type": "number",
                        "description": "Approximate token count before output truncation."
                    },
                    "output": {
                        "type": "string",
                        "description": "Command output text, possibly truncated."
                    }
                },
                "required": ["wall_time_seconds", "output"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "write_stdin",
            "description": "Continue or poll a live PTY/background terminal session created by `exec_command(tty=true)`. Use this to answer prompts, send control input, or fetch more output while the session keeps running. It does not start a new command.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "number",
                        "description": "PTY/background terminal session identifier returned by exec_command with tty=true."
                    },
                    "chars": {
                        "type": "string",
                        "description": "Text to send to terminal stdin. Leave empty to poll for more output without sending new input."
                    },
                    "yield_time_ms": {
                        "type": "number",
                        "description": "How long to wait before returning the latest terminal output. Use a short poll for responsive interaction and a longer wait for slow progress."
                    },
                    "max_output_tokens": {
                        "type": "number",
                        "description": "Maximum number of tokens to return. Excess output will be truncated."
                    }
                },
                "required": ["session_id"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "view_image",
            "description": "Load a local image file and attach it to the current round for visual analysis. Use this for screenshots, UI photos, camera photos, or saved error images on disk. Prefer local files under `media/`, especially `media/screenshots/` for Android screenshots.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "Local image path. Project files may use relative paths like media/screenshots/a.jpg or ./media/screenshots/a.jpg. Passing `media/screenshots/` or another image directory automatically picks the newest image file. Termux home may use the special alias home/... . External directories outside projectying should use absolute paths."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese purpose sentence for UI display, such as Õłåµ×ÉńĢīķØóµł¬ÕøŠ or µ¤źń£ŗµŖźķöÖÕøŠńēć."
                    },
                    "mode": {
                        "type": "string",
                        "enum": ["auto", "ui", "photo", "original"],
                        "description": "Optional image handling mode. auto (default) auto-detects screenshot vs photo and compresses locally. ui keeps text/buttons clearer with gentler compression. photo compresses more aggressively for object or scene recognition. original skips local resize/compression."
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Optional working directory used to resolve relative file paths; defaults to the current ProjectYing project root. Relative paths stay inside the project unless you explicitly use home/... or an absolute path."
                    },
                    "workdir": {
                        "type": "string",
                        "description": "Alias of cwd for compatibility."
                    }
                },
                "required": ["path"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "apply_patch",
            "description": "Apply a Codex-style patch for code edits. Inspect the file first, then patch the smallest reliable region. Prefer several small stable patch calls over one brittle large patch. The patch must use the original Codex envelope `*** Begin Patch` ... `*** End Patch`; do not use unified diff `---/+++` headers.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "input": {
                        "type": "string",
                        "description": "Full Codex `apply_patch` text. It must start with `*** Begin Patch` and end with `*** End Patch`. Each file block must use `*** Add File`, `*** Delete File`, or `*** Update File`; hunks must use `@@`; added file content lines must start with `+`. Use relative project paths by default; use absolute paths only when you intentionally edit outside ProjectYing."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese purpose sentence for UI display, such as õ┐«µö╣ķģŹńĮ«µ¢ćõ╗Č or Ķ░āµĢ┤ÕĘźÕģĘķĆ╗ĶŠæ."
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Optional working directory used to resolve relative file paths; defaults to the current ProjectYing project root. Relative patch paths stay inside the project unless you explicitly use home/... or an absolute path."
                    },
                    "workdir": {
                        "type": "string",
                        "description": "Alias of cwd for compatibility."
                    }
                },
                "required": ["input"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "update_plan",
            "description": "Visible plan tracker for complex multi-step work only. Use it when sequencing matters, the task is long enough to benefit from checkpoints, or the user explicitly wants a plan. Keep the plan concise, meaningful, and current. At most one step can be `in_progress` at a time.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "explanation": {
                        "type": "string",
                        "description": "Optional explanation for why the plan changed."
                    },
                    "plan": {
                        "type": "array",
                        "description": "Ordered plan steps. Keep them short and concrete, and keep exactly one step `in_progress` until the task is done.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "step": {
                                    "type": "string",
                                    "description": "Short task step."
                                },
                                "status": {
                                    "type": "string",
                                    "description": "One of: pending, in_progress, completed."
                                }
                            },
                            "required": ["step", "status"],
                            "additionalProperties": false
                        }
                    }
                },
                "required": ["plan"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "toolbox_manage",
            "description": "Manage the Matrix toolbox instead of treating provider schema as the source of truth. Use it to list current tool visibility or to open, close, pin, or unpin tool cards before calling them. Closed tools stay unavailable for direct use until opened. For visibility changes, always explain why the tool is needed now and what immediate plan it supports.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": ["list", "open", "close", "pin", "unpin"],
                        "description": "Toolbox action. Use `list` to inspect current state. Use the other actions to change visibility."
                    },
                    "tool_ids": {
                        "type": "array",
                        "description": "Stable tool ids to manage. Required for visibility-changing actions. Use tool ids, not UI order numbers.",
                        "items": {
                            "type": "string"
                        }
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese brief for UI display."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Required for visibility-changing actions. Explain why these tools should change state now."
                    },
                    "plan": {
                        "type": "string",
                        "description": "Required for visibility-changing actions. Explain the immediate execution plan after the toolbox update."
                    }
                },
                "required": ["action"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "task_mode",
            "description": "Enter or exit task mode directly. Use this for long chained work after planning: investigate, code, debug, migrate, or other focused execution. `enter` should declare the concrete task, why task mode starts now, plan_a / plan_b / fallback, expected_result, and exit_condition. `exit` should declare what was completed, what changed, key steps, key information worth carrying forward, the final result, and why task mode is ending. This is the preferred task-mode surface; `context_manage.task_enter/task_exit` remains only as a compatibility alias.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": ["enter", "exit", "task_enter", "task_exit", "focus_enter", "focus_exit"],
                        "description": "Task-mode action. Prefer `enter` / `exit`; the longer task_* / focus_* forms remain valid aliases."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese brief for UI, usually the task title."
                    },
                    "task": {
                        "type": "string",
                        "description": "Required for `enter`. The concrete focused task."
                    },
                    "user_goal": {
                        "type": "string",
                        "description": "Optional user goal for `enter`."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Optional reason explaining why task mode should start now."
                    },
                    "plan_a": {
                        "type": "string",
                        "description": "Optional primary execution plan for `enter`."
                    },
                    "plan_b": {
                        "type": "string",
                        "description": "Optional backup plan for `enter`."
                    },
                    "fallback": {
                        "type": "string",
                        "description": "Optional fallback strategy if both plan_a and plan_b fail."
                    },
                    "plan_c": {
                        "type": "string",
                        "description": "Legacy alias of `fallback` for compatibility."
                    },
                    "expected_result": {
                        "type": "string",
                        "description": "Optional expected result for `enter`."
                    },
                    "exit_condition": {
                        "type": "string",
                        "description": "Optional exit condition for `enter`."
                    },
                    "summary": {
                        "type": "string",
                        "description": "Required for `exit`. Final summary to carry back into standard context."
                    },
                    "completed": {
                        "type": "string",
                        "description": "Optional `exit` field describing what was completed."
                    },
                    "implemented": {
                        "type": "string",
                        "description": "Optional `exit` field describing what was implemented."
                    },
                    "steps": {
                        "type": "string",
                        "description": "Optional `exit` field listing the actual execution steps."
                    },
                    "key_info": {
                        "type": "string",
                        "description": "Optional `exit` field listing key information worth preserving."
                    },
                    "result": {
                        "type": "string",
                        "description": "Optional `exit` field describing the final result."
                    },
                    "exit_reason": {
                        "type": "string",
                        "description": "Optional `exit` field describing why task mode is ending."
                    },
                    "fastmemory_section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"],
                        "description": "Optional fastmemory section to write during `exit`."
                    },
                    "fastmemory_text": {
                        "type": "string",
                        "description": "Optional fastmemory note to write during `exit`."
                    }
                },
                "required": ["action"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "context_manage",
            "description": "Manage the external multi-file context store instead of editing context files directly. Use `task_mode` for enter/exit; keep `context_manage` for context maintenance and compatibility. Normal maintenance should be frequent `summary`, not delayed cleanup: use it to shrink or merge active context while preserving the facts that still matter. `write` is mainly for fastmemory and narrow structured writes; avoid free-form writes into `context` or `fastcontext` unless the system explicitly tells you to do so. `compact` is a low-frequency, full-area archival action, but threshold-driven system maintenance tickets may explicitly require whole-area `compact`; follow that ticket as written. When compacting standard context, the digest is archived into `fastcontext`, the protected latest 3 rounds stay in `context`, and surviving entries are renumbered. When a system maintenance ticket already provides `entry_ids` or `item_ids`, use those ids directly instead of rereading. If you already know the next tool call you need, do `context_manage` in the same round before that tool. Model-facing output is intentionally compact; the detailed diff stays in UI preview only.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": ["write", "summary", "compact", "task_enter", "task_exit", "focus_enter", "focus_exit", "replace"],
"description": "Context management action. Prefer `task_mode.enter` / `task_mode.exit`; `task_enter` / `task_exit` remain available here only as compatibility aliases, and legacy `focus_enter` / `focus_exit` remain valid too. `replace` is accepted as an alias of `summary`. `summary` is the normal high-frequency maintenance action for context, toolcontext, fastmemory, fastcontext, or adviceboard. `write` is mainly for fastmemory notes or narrowly-scoped structured writes. `compact` is low-frequency full-area archival compression, except when a threshold/system maintenance ticket explicitly asks for whole-area compact. For any `compact` call, `text` is required and must contain the new condensed replacement summary (Compact_TEXT) that should remain after compression."
                    },
                    "target": {
                        "type": "string",
                        "enum": ["context", "toolcontext", "focuscontext", "fastmemory", "fastcontext", "adviceboard"],
                        "description": "Target store for write / summary / compact. Prefer `toolcontext`; legacy `focuscontext` remains a valid alias. Standard `context` is the active conversation log and includes the protected latest 3 rounds. `fastmemory` stores durable short facts. `fastcontext` is the archive pool fed by context compaction. `toolcontext` is the temporary task-mode work area. `adviceboard` is the shared audit board for Matrix and the internal advisor pipeline."
                    },
                    "section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"],
                        "description": "Required when target is fastmemory."
                    },
                    "role": {
                        "type": "string",
                        "enum": ["user", "assistant", "system"],
                        "description": "Optional role for summary/compact digests on context or toolcontext. Do not use this to append free-form context history."
                    },
                    "kind": {
                        "type": "string",
                        "description": "Optional context entry kind for write / summary, such as note or summary."
                    },
                    "round_id": {
                        "type": "number",
                        "description": "Optional round id when writing directly into context or toolcontext."
                    },
                    "entry_ids": {
                        "type": "array",
                        "description": "Entry ids for `summary` on `context` or `toolcontext`. `summary` may target one entry or many entries and merge them into one surviving summary. If a system maintenance ticket already gives `entry_ids`, use them directly. For `compact`, omitting this means compact the whole target area while automatically protecting the latest 3 rounds in standard context.",
                        "items": { "type": "number" }
                    },
                    "item_ids": {
                        "type": "array",
                        "description": "Item ids for `summary` or `compact` on `fastcontext` or `adviceboard` when the system already gave exact items.",
                        "items": { "type": "number" }
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese summary for UI display."
                    },
                    "text": {
                        "type": "string",
"description": "Content for `write`, or the merged digest for `summary` / `compact`. For `compact`, this field is required and must be the new condensed replacement summary (Compact_TEXT) that should remain after archival compression."
                    },
                    "task": {
                        "type": "string",
                        "description": "Required for task_enter / focus_enter. The concrete focused task."
                    },
                    "user_goal": {
                        "type": "string",
                        "description": "Optional user goal for task_enter / focus_enter."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Optional reason explaining why the model should enter task mode now."
                    },
                    "plan_a": {
                        "type": "string",
                        "description": "Optional primary execution plan for task_enter / focus_enter."
                    },
                    "plan_b": {
                        "type": "string",
                        "description": "Optional secondary execution plan for task_enter / focus_enter."
                    },
                    "fallback": {
                        "type": "string",
                        "description": "Optional fallback strategy for task_enter / focus_enter when plan_a and plan_b both fail."
                    },
                    "plan_c": {
                        "type": "string",
                        "description": "Legacy alias of fallback for compatibility."
                    },
                    "expected_result": {
                        "type": "string",
                        "description": "Optional expected result for task_enter / focus_enter."
                    },
                    "exit_condition": {
                        "type": "string",
                        "description": "Optional exit condition for task_enter / focus_enter."
                    },
                    "summary": {
                        "type": "string",
                        "description": "Required for task_exit / focus_exit. Final summary that should be written back to standard context."
                    },
                    "completed": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field describing what was completed."
                    },
                    "implemented": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field describing what was implemented."
                    },
                    "steps": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field listing the actual execution steps."
                    },
                    "key_info": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field listing the key information worth preserving."
                    },
                    "result": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field describing the final result."
                    },
                    "exit_reason": {
                        "type": "string",
                        "description": "Optional task_exit / focus_exit field describing why task mode is being exited now."
                    },
                    "fastmemory_section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"],
                        "description": "Optional fastmemory section to write during task_exit / focus_exit."
                    },
                    "fastmemory_text": {
                        "type": "string",
                        "description": "Optional fastmemory text to write during task_exit / focus_exit."
                    }
                },
                "required": ["action"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "memory_add",
            "description": "Write one or more dated diary entries into `datememory`. Most often this is triggered when the system asks you to compress `datememorycontext` into long-term memory. Split by actual diary date; the same date may have multiple entries. Write like a human recall or journal entry with concrete events and keywords, not like a mechanical tool log.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "entries": {
                        "type": "array",
                        "description": "One or more date diary entries. Split records by diary date; the same date may appear multiple times. Each entry is written into datememory as a separate dated segment.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "date": {
                                    "type": "string",
                                    "description": "Diary date in YYYY-MM-DD format."
                                },
                                "title": {
                                    "type": "string",
                                    "description": "Optional short diary title."
                                },
                                "keywords": {
                                    "type": "array",
                                    "description": "Important recall keywords for future lookup, such as people, project names, tasks, problems, results, emotions, places, or tool names.",
                                    "items": { "type": "string" }
                                },
                                "summary": {
                                    "type": "string",
                                    "description": "Optional short summary."
                                },
                                "evidence_entry_ids": {
                                    "type": "array",
                                    "description": "Optional stable evidence entry ids that anchor this diary memory back to raw conversation/tool facts. Use these when the diary was compressed from known context entry ids.",
                                    "items": { "type": "number" }
                                },
                                "content": {
                                    "type": "string",
                                    "description": "Detailed diary-style content for that date. Write it like a human memory or journal entry, with time flow and key events, not a mechanical AI summary."
                                }
                            },
                            "required": ["date", "content"],
                            "additionalProperties": false
                        }
                    },
                    "clear_context": {
                        "type": "boolean",
                        "description": "When true, clear datememorycontext only after all entries are written successfully. This is the normal setting for system-triggered memory maintenance."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese summary for UI display."
                    }
                },
                "required": ["entries"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "memory_replace",
            "description": "Replace an existing `datememory` diary entry by `entry_id`. Use this when a stored long-term memory entry is wrong, incomplete, or should be rewritten more clearly.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "entry_id": {
                        "type": "number",
                        "description": "Existing datememory entry id."
                    },
                    "date": {
                        "type": "string",
                        "description": "Diary date in YYYY-MM-DD format."
                    },
                    "title": {
                        "type": "string",
                        "description": "Optional short diary title."
                    },
                    "keywords": {
                        "type": "array",
                        "description": "Important keywords for future lookup.",
                        "items": { "type": "string" }
                    },
                    "summary": {
                        "type": "string",
                        "description": "Optional short summary."
                    },
                    "evidence_entry_ids": {
                        "type": "array",
                        "description": "Optional stable evidence entry ids that this replacement diary entry should keep pointing to.",
                        "items": { "type": "number" }
                    },
                    "content": {
                        "type": "string",
                        "description": "Full replacement content."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese summary for UI display."
                    }
                },
                "required": ["entry_id", "date", "content"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "memory_check",
            "description": "First-pass locator for long-term memory before deep reading. Start here to find the relevant day, date window, or entry group. `datememory` helps locate human diary-style memories by date. `metamemory`, `contextmemory`, and `toolmemory` should usually be located by keywords and time range first, then refined directly with `memory_read` once ids or dates are clear.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "enum": ["datememory", "metamemory", "contextmemory", "toolmemory"],
                        "description": "Which long-term memory store to search."
                    },
                    "keywords": {
                        "type": "array",
                        "description": "Search keywords. Prefer 1-5 concrete keywords that are likely to co-occur, such as people, tasks, project names, bugs, tools, or results.",
                        "items": { "type": "string" }
                    },
                    "scope": {
                        "type": "string",
                        "enum": ["recent", "past", "old", "custom"],
                        "description": "Search scope. Default is recent. recent=recent 3 months, past=3-12 months, old=>1 year, custom=start/end range."
                    },
                    "date": {
                        "type": "string",
                        "description": "Exact date in YYYY-MM-DD format. Optional exact-day filter for any store."
                    },
                    "start_date": {
                        "type": "string",
                        "description": "Custom start date in YYYY-MM-DD format."
                    },
                    "end_date": {
                        "type": "string",
                        "description": "Custom end date in YYYY-MM-DD format."
                    },
                    "tool_ref": {
                        "type": "string",
                        "description": "Legacy exact toolmemory ref lookup. Prefer keywords/date unless you already know the ref."
                    },
                    "limit": {
                        "type": "number",
                        "description": "Optional result limit. Keep this small when you are locating and will refine with search/read next."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese summary for UI display."
                    }
                },
                "required": ["target"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "memory_read",
            "description": "Read long-term memory in detail. Use this only after you already know the day, entry id, or narrow range you need. `datememory` can read a full day, one entry, or a contiguous entry-id range. `metamemory` reads a specific day and can be narrowed by line range. `contextmemory` can read a full day, one entry, or a contiguous entry-id range. `toolmemory` should normally be read by entry id, with `tool_ref` kept only as a legacy fallback.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "enum": ["datememory", "metamemory", "contextmemory", "toolmemory"],
                        "description": "Which long-term memory store to read."
                    },
                    "date": {
                        "type": "string",
                        "description": "Exact date in YYYY-MM-DD format."
                    },
                    "tool_ref": {
                        "type": "string",
                        "description": "Legacy exact tool_ref for toolmemory read. Prefer entry_id."
                    },
                    "entry_id": {
                        "type": "number",
                        "description": "Specific datememory, contextmemory, or toolmemory entry id."
                    },
                    "entry_start_id": {
                        "type": "number",
                        "description": "Optional datememory or contextmemory start entry id for contiguous range reading."
                    },
                    "entry_end_id": {
                        "type": "number",
                        "description": "Optional datememory or contextmemory end entry id for contiguous range reading."
                    },
                    "line_start": {
                        "type": "number",
                        "description": "Optional 1-based start line for metamemory or fine-grained datememory/toolmemory transcript reads."
                    },
                    "line_end": {
                        "type": "number",
                        "description": "Optional 1-based end line for metamemory or fine-grained datememory/toolmemory transcript reads."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese summary for UI display."
                    }
                },
                "required": ["target"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "request_user_input",
            "description": "Request structured user input through the inline reconciliation UI and wait for the reply. Use this only when the user must settle implementation details, compare design choices, or fill in missing constraints. Prefer a single concise question; ask multiple items only when they are tightly related. Suggested options should stay short, while the custom answer path remains the primary route.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "questions": {
                        "type": "array",
                        "description": "Questions to show in the reconciliation UI. Prefer 1 and do not exceed 10. Use this for genuine implementation reconciliation, not casual chat or things you can infer safely.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Stable unique identifier for mapping answers, such as confirm_path."
                                },
                                "header": {
                                    "type": "string",
                                    "description": "Short header label shown in the UI (12 or fewer chars); keep it compact for the inline input area."
                                },
                                "question": {
                                    "type": "string",
                                    "description": "Single-sentence prompt shown to the user."
                                },
                                "options": {
                                    "type": "array",
                                    "description": "Provide 1-3 mutually exclusive suggested choices. Put the recommended option first when applicable, keep labels concise, and remember the UI will also provide a custom answer path as the main free-form route.",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "label": {
                                                "type": "string",
                                                "description": "User-facing label (1-5 words)."
                                            },
                                            "description": {
                                                "type": "string",
                                                "description": "One short sentence explaining impact or tradeoff if selected."
                                            }
                                        },
                                        "required": ["label", "description"],
                                        "additionalProperties": false
                                    }
                                }
                            },
                            "required": ["id", "header", "question", "options"],
                            "additionalProperties": false
                        }
                    }
                },
                "required": ["questions"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "spawn_agent",
            "description": "Spawn a sub-agent for a well-scoped side task, bounded exploration, or parallel batch work. Delegate only when it materially helps: the task should be concrete, self-contained, and worth parallelizing. Do not hand off the immediate blocking step when the main thread can just finish it directly.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "Initial plain-text task for the new agent. Use either message or items."
                    },
                    "items": {
                        "type": "array",
                        "description": "Structured input items. Use this to pass explicit mentions or non-text payloads.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": { "type": "string" },
                                "text": { "type": "string" },
                                "image_url": { "type": "string" },
                                "path": { "type": "string" },
                                "name": { "type": "string" }
                            },
                            "additionalProperties": false
                        }
                    },
                    "agent_type": {
                        "type": "string",
                        "description": "Optional agent role label, such as worker or explorer."
                    },
                    "fork_context": {
                        "type": "boolean",
                        "description": "When true, fork the current thread history into the new agent."
                    },
                    "model": {
                        "type": "string",
                        "description": "Optional model override for the new agent."
                    },
                    "reasoning_effort": {
                        "type": "string",
                        "description": "Optional reasoning effort override for the new agent."
                    }
                },
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "agent_id": {
                        "type": "string",
                        "description": "Thread-like identifier for the spawned agent."
                    },
                    "nickname": {
                        "type": ["string", "null"],
                        "description": "User-facing nickname when available."
                    }
                },
                "required": ["agent_id", "nickname"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "send_input",
            "description": "Send follow-up instructions, corrections, or extra material to an existing agent. Use this to refine scope or provide missing input without spawning a new agent. Set `interrupt=true` only when the current direction is wrong or must be redirected immediately.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Agent id to message (from spawn_agent)."
                    },
                    "message": {
                        "type": "string",
                        "description": "Legacy plain-text message to send to the agent. Use either message or items."
                    },
                    "items": {
                        "type": "array",
                        "description": "Structured input items. Use this to pass explicit mentions or non-text payloads.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "type": { "type": "string" },
                                "text": { "type": "string" },
                                "image_url": { "type": "string" },
                                "path": { "type": "string" },
                                "name": { "type": "string" }
                            },
                            "additionalProperties": false
                        }
                    },
                    "interrupt": {
                        "type": "boolean",
                        "description": "When true, stop the agent's current task and handle this immediately."
                    }
                },
                "required": ["id"],
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "submission_id": {
                        "type": "string",
                        "description": "Identifier for the queued input submission."
                    }
                },
                "required": ["submission_id"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "wait_agent",
            "description": "Wait for agents to reach a final status or return a timeout snapshot. Use this when you need the result now or want a progress checkpoint. If the timeout expires first, inspect the returned progress lines and either keep working locally or wait again; timeout does not imply failure.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "ids": {
                        "type": "array",
                        "description": "Agent ids to wait on. Pass multiple ids to wait for whichever finishes first.",
                        "items": {
                            "type": "string"
                        }
                    },
                    "timeout_ms": {
                        "type": "number",
                        "description": "Optional timeout in milliseconds. Defaults to 30000 and clamps to 10000..3600000. For real worker tasks, prefer a longer timeout such as 60000-300000."
                    }
                },
                "required": ["ids"],
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "object",
                        "description": "Latest observed statuses keyed by agent id. On timeout this can include running or pending agents."
                    },
                    "timed_out": {
                        "type": "boolean",
                        "description": "Whether the wait returned due to timeout before any watched agent reached a final status."
                    },
                    "progress": {
                        "type": "array",
                        "description": "Compact progress lines for each watched agent, suitable for quick polling updates.",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "required": ["status", "timed_out", "progress"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "list_agent",
            "description": "List known sub-agents, including closed ones and their log paths. Use this to inspect current agent state, understand what already exists, or decide whether to wait, resume, close, or reuse an agent.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "include_closed": {
                        "type": "boolean",
                        "description": "When true, include closed agents and their log files. Defaults to true."
                    }
                },
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "count": {
                        "type": "number"
                    },
                    "agents": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": { "type": "string" },
                                "nickname": { "type": ["string", "null"] },
                                "agent_type": { "type": ["string", "null"] },
                                "status": {},
                                "task_preview": { "type": "string" },
                                "latest_event": { "type": ["string", "null"] },
                                "log_path": { "type": "string" },
                                "created_at": { "type": "number" }
                            },
                            "required": ["id", "nickname", "agent_type", "status", "task_preview", "latest_event", "log_path", "created_at"],
                            "additionalProperties": false
                        }
                    }
                },
                "required": ["count", "agents"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "resume_agent",
            "description": "Resume a previously closed agent by id so it can receive `send_input` and `wait_agent` calls again. Use this when the prior agent context is still useful and reopening it is cheaper than spawning a fresh one.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Agent id to resume."
                    }
                },
                "required": ["id"],
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "status": {}
                },
                "required": ["status"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "close_agent",
            "description": "Close one or more agents when they are no longer needed and return their latest status summary. Use this to retire finished or abandoned side-task agents and keep the agent pool tidy.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Single agent id to close."
                    },
                    "ids": {
                        "type": "array",
                        "description": "Optional batch close list. Prefer this when multiple agents should be closed together.",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "additionalProperties": false
            },
            "output_schema": {
                "type": "object",
                "properties": {
                    "statuses": {}
                },
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "spawn_agents_on_csv",
            "description": "Process a CSV by applying an instruction template to each row. Use this for repeatable row-wise batch work that should fan out into many bounded workers. The instruction string may use `{column_name}` placeholders. Results are exported to a CSV file on completion. Row workers report through the internal `report_agent_job_result` flow; the main agent should not call that tool directly.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "csv_path": {
                        "type": "string",
                        "description": "Path to the CSV file containing input rows."
                    },
                    "instruction": {
                        "type": "string",
                        "description": "Instruction template to apply to each CSV row. Use {column_name} placeholders to inject values from that row."
                    },
                    "id_column": {
                        "type": "string",
                        "description": "Optional column name to use as a stable item id."
                    },
                    "output_csv_path": {
                        "type": "string",
                        "description": "Optional output CSV path for exported results."
                    },
                    "output_schema": {
                        "type": "object",
                        "description": "Optional JSON schema that each worker result should follow."
                    },
                    "max_concurrency": {
                        "type": "number",
                        "description": "Maximum concurrent workers. Defaults to 16 and caps at 64."
                    },
                    "max_workers": {
                        "type": "number",
                        "description": "Alias for max_concurrency."
                    },
                    "max_runtime_seconds": {
                        "type": "number",
                        "description": "Maximum runtime per worker before it is failed. Defaults to 1800 seconds."
                    }
                },
                "required": ["csv_path", "instruction"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "report_agent_job_result",
            "description": "Worker-only tool to report a result for an agent job item. Main agents should not call this directly.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "job_id": {
                        "type": "string",
                        "description": "Identifier of the job."
                    },
                    "item_id": {
                        "type": "string",
                        "description": "Identifier of the job item."
                    },
                    "result": {
                        "type": "object",
                        "description": "Structured result payload for the job item."
                    },
                    "stop": {
                        "type": "boolean",
                        "description": "When true, cancel remaining job items after this result is recorded."
                    }
                },
                "required": ["job_id", "item_id", "result"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "pty_list",
            "description": "List currently running PTY/background terminal sessions. Use this before polling or killing sessions when you need the current live terminal inventory.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {},
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "pty_kill",
            "description": "Terminate one or more PTY/background terminal sessions. Use this to stop abandoned or no-longer-needed terminal jobs cleanly.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "session_id": {
                        "type": "number",
                        "description": "Single background terminal session identifier to terminate."
                    },
                    "session_ids": {
                        "type": "array",
                        "description": "Optional batch terminate list. Prefer this when multiple PTY sessions should be stopped together.",
                        "items": {
                            "type": "number"
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    ])
