    json!([
        {
            "type": "function",
            "name": "exec_command",
            "description": "Run a one-shot shell command for local coding work. This Coding persona does not support PTY, background terminal, or `write_stdin`, so prefer precise reads, focused builds/tests, and deterministic validation commands. Normal flow is: inspect narrowly, modify, then verify. When several independent read/search commands are needed, emit them directly in the same round; the runtime can batch eligible read-only calls natively.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "cmd": {
                        "type": "string",
                        "description": "Shell command to execute. Prefer precise reads and targeted validation over giant dumps."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese purpose sentence for UI display."
                    },
                    "workdir": {
                        "type": "string",
                        "description": "Optional working directory. Relative paths resolve from the current ProjectYing project root; use absolute paths for external directories."
                    },
                    "shell": {
                        "type": "string",
                        "description": "Shell binary to launch. Defaults to the current shell."
                    },
                    "yield_time_ms": {
                        "type": "number",
                        "description": "How long to wait before yielding output. Use a short wait for file inspection and a longer one for builds, tests, or slow startup commands."
                    },
                    "output_level": {
                        "type": "string",
                        "enum": ["low", "medium", "high"],
                        "description": "Visible output budget for one-shot commands. Default is `medium`. Presets follow Settings -> 上下文: low=120 lines / 36000 chars, medium=320 lines / 96000 chars, high=520 lines / 156000 chars. If output exceeds the chosen budget, full output is exported and a summary is returned."
                    },
                    "max_output_tokens": {
                        "type": "number",
                        "description": "Legacy optional token cap applied after line-budget/export handling."
                    },
                    "login": {
                        "type": "boolean",
                        "description": "Whether to run the shell with login semantics. Defaults to true."
                    }
                },
                "required": ["cmd"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "apply_patch",
            "description": "Apply a Codex-style patch for normal code edits. Inspect first, then patch the smallest reliable region. Split large risky edits into several stable patch calls instead of forcing one brittle patch. Use the original Codex envelope `*** Begin Patch` ... `*** End Patch`; do not use unified diff `---/+++` headers.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "input": {
                        "type": "string",
                        "description": "Full Codex `apply_patch` text. It must start with `*** Begin Patch` and end with `*** End Patch`. Each file block must use `*** Add File`, `*** Delete File`, or `*** Update File`; hunks must use `@@`."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese purpose sentence for UI display."
                    },
                    "workdir": {
                        "type": "string",
                        "description": "Optional working directory used to resolve relative patch paths."
                    },
                    "cwd": {
                        "type": "string",
                        "description": "Alias of workdir."
                    }
                },
                "required": ["input"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "update_plan",
            "description": "Visible task plan tracker for complex coding work only. Use it when sequencing matters, the task is long enough to need checkpoints, or the user explicitly asks for planning. Keep the plan concise and keep exactly one step active at a time.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "explanation": {
                        "type": "string",
                        "description": "Optional short explanation of why the plan changed."
                    },
                    "plan": {
                        "type": "array",
                        "description": "Ordered plan steps. Keep them short and concrete, and keep exactly one step `in_progress` until the task is done.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "step": {
                                    "type": "string",
                                    "description": "Short step title."
                                },
                                "status": {
                                    "type": "string",
                                    "enum": ["pending", "in_progress", "completed"],
                                    "description": "Current step status."
                                }
                            },
                            "required": ["step", "status"],
                            "additionalProperties": false
                        }
                    }
                },
                "required": ["plan"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "task_mode",
            "description": "Enter or exit task mode directly for long coding chains. Use it after planning when you are about to inspect, patch, test, refactor, or debug across multiple dependent steps. `enter` should declare the concrete coding task, why task mode starts now, plan_a / plan_b / fallback, expected_result, and exit_condition. `exit` should declare what was completed, what changed, key steps, key information worth preserving, the final result, and why task mode is ending. This is the preferred task-mode surface; `context_manage.task_enter/task_exit` remains only as a compatibility alias.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": ["enter", "exit", "task_enter", "task_exit", "focus_enter", "focus_exit"],
                        "description": "Task-mode action. Prefer `enter` / `exit`; the longer task_* / focus_* forms remain valid aliases."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese brief for UI, usually the task title."
                    },
                    "task": {
                        "type": "string",
                        "description": "Required for `enter`. The concrete focused coding task."
                    },
                    "user_goal": {
                        "type": "string",
                        "description": "Optional user goal for `enter`."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Optional reason for starting task mode now."
                    },
                    "plan_a": {
                        "type": "string",
                        "description": "Optional primary execution plan for `enter`."
                    },
                    "plan_b": {
                        "type": "string",
                        "description": "Optional backup plan for `enter`."
                    },
                    "fallback": {
                        "type": "string",
                        "description": "Optional fallback strategy if both plan_a and plan_b fail."
                    },
                    "plan_c": {
                        "type": "string",
                        "description": "Legacy alias of `fallback` for compatibility."
                    },
                    "expected_result": {
                        "type": "string",
                        "description": "Optional expected result for `enter`."
                    },
                    "exit_condition": {
                        "type": "string",
                        "description": "Optional exit condition for `enter`."
                    },
                    "summary": {
                        "type": "string",
                        "description": "Required for `exit`. Final summary to carry back into standard context."
                    },
                    "completed": {
                        "type": "string",
                        "description": "Optional `exit` field describing what was completed."
                    },
                    "implemented": {
                        "type": "string",
                        "description": "Optional `exit` field describing what was implemented."
                    },
                    "steps": {
                        "type": "string",
                        "description": "Optional `exit` field listing the actual execution steps."
                    },
                    "key_info": {
                        "type": "string",
                        "description": "Optional `exit` field listing key information worth preserving."
                    },
                    "result": {
                        "type": "string",
                        "description": "Optional `exit` field describing the final result."
                    },
                    "exit_reason": {
                        "type": "string",
                        "description": "Optional `exit` field describing why task mode is ending."
                    },
                    "fastmemory_section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"],
                        "description": "Optional fastmemory section to write during `exit`."
                    },
                    "fastmemory_text": {
                        "type": "string",
                        "description": "Optional fastmemory note to write during `exit`."
                    }
                },
                "required": ["action"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "context_manage",
            "description": "Manage the external context store instead of editing context files directly. Use `task_mode` for enter/exit; keep `context_manage` for context maintenance and compatibility. Normal maintenance should be frequent `summary`, not delayed cleanup. Use `summary` to shrink or merge active working memory while keeping facts that still matter. `write` is mainly for fastmemory and narrow structured writes; avoid free-form writes into `context` or `fastcontext` unless the system explicitly asks. `compact` is a low-frequency full-area archival action, but threshold-driven system maintenance tickets may explicitly require whole-area `compact`; follow that ticket as written. When a system message already gives `entry_ids` or `item_ids`, use those ids directly. If you already know the next tool call you need, do `context_manage` in the same round before that tool. Model-facing output is intentionally compact; the detailed diff stays in UI preview only.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": ["write", "summary", "compact", "task_enter", "task_exit", "focus_enter", "focus_exit", "replace"],
"description": "Context action. Prefer `task_mode.enter` / `task_mode.exit`; `task_enter` / `task_exit` remain available here only as compatibility aliases, and legacy `focus_enter` / `focus_exit` remain valid too. `replace` is accepted as an alias of `summary`. `summary` is the normal high-frequency maintenance action. `write` is mainly for fastmemory notes or narrow structured writes. `compact` is whole-area archival compression, and should be used directly when a threshold/system maintenance ticket explicitly asks for it. For any `compact` call, `text` is required and must contain the new condensed replacement summary (Compact_TEXT) that should remain after compression."
                    },
                    "target": {
                        "type": "string",
                        "enum": ["context", "toolcontext", "focuscontext", "fastmemory", "fastcontext"],
                        "description": "Target area for write/summary/compact. Prefer `toolcontext`; legacy `focuscontext` remains a valid alias. `context` is the active conversation log, `fastmemory` stores durable short facts, `fastcontext` is the archive pool, and `toolcontext` is the temporary task-mode work area."
                    },
                    "section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"],
                        "description": "Fastmemory section when target is fastmemory."
                    },
                    "role": {
                        "type": "string",
                        "enum": ["user", "assistant", "system"],
                        "description": "Role for write/summary requests when needed."
                    },
                    "kind": {
                        "type": "string",
                        "description": "Optional logical kind label for the rewritten entry."
                    },
                    "round_id": {
                        "type": "number",
                        "description": "Optional round id for write requests."
                    },
                    "entry_ids": {
                        "type": "array",
                        "items": { "type": "number" },
                        "description": "Entry ids for `summary` or `compact` on `context` / `toolcontext`. When the system already gives `entry_ids`, use them directly instead of rereading."
                    },
                    "item_ids": {
                        "type": "array",
                        "items": { "type": "number" },
                        "description": "Item ids for `summary` or `compact` on `fastmemory` / `fastcontext`. When the system already gives `item_ids`, use them directly instead of rereading."
                    },
                    "brief": {
                        "type": "string",
                        "description": "Optional short Chinese brief for UI."
                    },
                    "text": {
                        "type": "string",
                        "description": "Main summary or write text. For `summary`, write the condensed surviving text that should remain after merging or shrinking the selected entries/items. Preserve key facts only."
                    },
                    "task": {
                        "type": "string",
                        "description": "Required for `task_enter` / `focus_enter`. The concrete focused coding task."
                    },
                    "user_goal": {
                        "type": "string",
                        "description": "Optional user goal for `task_enter` / `focus_enter`."
                    },
                    "reason": {
                        "type": "string",
                        "description": "Optional reason explaining why task mode should start now."
                    },
                    "plan_a": {
                        "type": "string",
                        "description": "Optional primary plan for `task_enter` / `focus_enter`."
                    },
                    "plan_b": {
                        "type": "string",
                        "description": "Optional secondary plan for `task_enter` / `focus_enter`."
                    },
                    "fallback": {
                        "type": "string",
                        "description": "Optional fallback strategy if both plan A and plan B fail."
                    },
                    "plan_c": {
                        "type": "string",
                        "description": "Legacy alias of `fallback` for compatibility."
                    },
                    "expected_result": {
                        "type": "string",
                        "description": "Optional expected result for `task_enter` / `focus_enter`."
                    },
                    "exit_condition": {
                        "type": "string",
                        "description": "Optional exit condition for `task_enter` / `focus_enter`."
                    },
                    "summary": {
                        "type": "string",
                        "description": "Required for `task_exit` / `focus_exit`. Final summary that should be written back to standard context."
                    },
                    "completed": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field describing what was completed."
                    },
                    "implemented": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field describing what was implemented."
                    },
                    "steps": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field listing the actual execution steps."
                    },
                    "key_info": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field listing key information worth preserving."
                    },
                    "result": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field describing the final result."
                    },
                    "exit_reason": {
                        "type": "string",
                        "description": "Optional `task_exit` / `focus_exit` field describing why task mode is ending."
                    },
                    "fastmemory_section": {
                        "type": "string",
                        "enum": ["environment", "self", "user", "event"]
                    },
                    "fastmemory_text": { "type": "string" }
                },
                "required": ["action"],
                "additionalProperties": false
            }
        },
        {
            "type": "function",
            "name": "request_user_input",
            "description": "Ask the user for structured clarification or design reconciliation through the input area. Use this only when the implementation genuinely depends on a user decision or missing requirement. Prefer one concise question; each question supports 1-3 suggested options and an automatic custom answer path.",
            "strict": false,
            "parameters": {
                "type": "object",
                "properties": {
                    "questions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "description": "Stable snake_case identifier."
                                },
                                "header": {
                                    "type": "string",
                                    "description": "Short header label."
                                },
                                "question": {
                                    "type": "string",
                                    "description": "Single-sentence prompt shown to the user."
                                },
                                "options": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "label": {
                                                "type": "string",
                                                "description": "User-facing option label."
                                            },
                                            "description": {
                                                "type": "string",
                                                "description": "Short tradeoff description."
                                            }
                                        },
                                        "required": ["label", "description"],
                                        "additionalProperties": false
                                    }
                                }
                            },
                            "required": ["id", "header", "question", "options"],
                            "additionalProperties": false
                        }
                    }
                },
                "required": ["questions"],
                "additionalProperties": false
            }
        }
    ])
